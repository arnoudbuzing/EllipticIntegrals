Notebook[{
Cell["EllipticIntegrals Performance Benchmarks", "Title",ExpressionUUID->"00057106-a9a0-471e-945a-dc9180dd21b2"],

Cell["\<\
This notebook benchmarks the performance of the Rust-bound paclet functions \
against Wolfram Language's built-in elliptic integrals. \
\>", "Text",ExpressionUUID->"0064a4ee-0f39-4dc6-81f8-0313fb21677c"],

Cell["Loading the Paclet", "Section",ExpressionUUID->"c354096d-394b-416d-8137-347aa843e706"],

Cell["Ensure the paclet is loaded: ", "CodeText",ExpressionUUID->"ac622102-385d-4606-9a15-97cf79dc9eda"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Load", " ", "local", " ", "paclet"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"DirectoryName", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Needs", "[", "\"\<ArnoudBuzing`EllipticIntegrals`\>\"", 
    "]"}]}]}]], "Input",ExpressionUUID->"d521223f-a8c0-4ce0-8740-\
62f43ca69ddc"],

Cell["Generating Benchmark Datasets", "Section",ExpressionUUID->"a42eec6d-4d2e-419b-afab-fc5990d3c155"],

Cell["\<\
We generate large lists of random, unique real numbers to evaluate our \
functions over: \
\>", "CodeText",ExpressionUUID->"46565677-d9db-4a50-bb2b-a93319c608f0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nPoints", "=", "100000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Legendre", " ", "parameter", " ", "domains", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "<", " ", "1"}], ",", " ", 
      RowBox[{"n", " ", "<", " ", "1"}]}], ")"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataLegendre1D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "2.0"}], ",", "0.99"}], "}"}], ",", "nPoints"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dataLegendre2D", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2.0"}], ",", "0.99"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"nPoints", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Carlson", " ", "parameter", " ", "domains", " ", 
    RowBox[{"(", 
     RowBox[{"variables", " ", ">", " ", "0"}], ")"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataCarlson3D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.01", ",", "10.0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"nPoints", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataCarlson4D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.01", ",", "10.0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"nPoints", ",", "4"}], "}"}]}], "]"}]}], ";"}]}], "Input",Expres\
sionUUID->"431c1b0f-7aac-4de1-b034-08238ce73258"],

Cell["Benchmarking Function", "Section",ExpressionUUID->"fc04780b-bf48-4539-b270-9e8177fc0259"],

Cell["\<\
We define a helper function to measure absolute timing for both Rust and \
built-in WL: \
\>", "CodeText",ExpressionUUID->"2b29e828-be62-4ca8-a63d-9066db985129"],

Cell[BoxData[
 RowBox[{
  RowBox[{"runBenchmark", "[", 
   RowBox[{"name_String", ",", "fRust_", ",", "fWL_", ",", "data_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", "  ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"tRust", ",", "tWL", ",", "ratio"}], "}"}], ",", 
    "\[IndentingNewLine]", "  ", 
    RowBox[{"(*", " ", 
     RowBox[{"Warm", " ", "up"}], " ", "*)"}], "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{
        RowBox[{"fRust", " ", "@@", " ", 
         RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
        "    ", 
        RowBox[{"fWL", " ", "@@", " ", 
         RowBox[{"First", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
       "    ", ",", "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"fRust", "[", 
         RowBox[{"First", "[", "data", "]"}], "]"}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"fWL", "[", 
         RowBox[{"First", "[", "data", "]"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "  ", "]"}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"tRust", "=", 
      RowBox[{"First", "[", 
       RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", "    ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
           "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fRust", " ", "@@", " ", "item"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fRust", "[", "item", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "    ", "]"}], ";"}], "\[IndentingNewLine]", 
        "  ", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"tWL", "=", 
      RowBox[{"First", "[", 
       RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", "    ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
           "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fWL", " ", "@@", " ", "item"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fWL", "[", "item", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "    ", "]"}], ";"}], "\[IndentingNewLine]", 
        "  ", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"<|", "\[IndentingNewLine]", "    ", 
      RowBox[{
       RowBox[{"\"\<Function\>\"", "->", "name"}], ",", "\[IndentingNewLine]",
        "    ", 
       RowBox[{"\"\<Rust Time (s)\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{"tRust", ",", "0.0001"}], "]"}]}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"\"\<WL Time (s)\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{"tWL", ",", "0.0001"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{"\"\<Speedup\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"tWL", "/", "tRust"}], ",", "0.1"}], "]"}]}]}], 
      "\[IndentingNewLine]", "  ", "|>"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",ExpressionUUID->"711e37bc-0857-46bf-9170-2c74bfce877a"],

Cell["Running the Benchmarks", "Section",ExpressionUUID->"44cf73b8-84d1-49fc-95a1-b377582a9d07"],

Cell["Execute the speed comparisons: ", "CodeText",ExpressionUUID->"b85a612b-de93-4a78-b562-3c367a0b843c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{"{", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rEllipticK / EllipticK\>\"", ",", "rEllipticK", ",", 
       "EllipticK", ",", "dataLegendre1D"}], "]"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rEllipticE / EllipticE\>\"", ",", "rEllipticE", ",", 
       "EllipticE", ",", "dataLegendre1D"}], "]"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rEllipticPi / EllipticPi\>\"", ",", "rEllipticPi", ",", 
       "EllipticPi", ",", "dataLegendre2D"}], "]"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rCarlsonRF / CarlsonRF\>\"", ",", "rCarlsonRF", ",", 
       "CarlsonRF", ",", "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]",
      "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rCarlsonRG / CarlsonRG\>\"", ",", "rCarlsonRG", ",", 
       "CarlsonRG", ",", "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]",
      "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rCarlsonRD / CarlsonRD\>\"", ",", "rCarlsonRD", ",", 
       "CarlsonRD", ",", "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]",
      "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<rCarlsonRJ / CarlsonRJ\>\"", ",", "rCarlsonRJ", ",", 
       "CarlsonRJ", ",", "dataCarlson4D"}], "]"}]}], "\[IndentingNewLine]", 
    "}"}]}], ";"}]], "Input",ExpressionUUID->"9f3dc1db-a939-49a4-b831-\
b8eb5b039cfa"],

Cell["Displaying Results", "Section",ExpressionUUID->"c2ffa0a0-63f0-429e-a03d-d33c49148278"],

Cell["Display the timing metrics as a dataset: ", "CodeText",ExpressionUUID->"85363431-fac2-46bb-984c-56bd4ee2307c"],

Cell[BoxData[
 RowBox[{"Dataset", "[", "results", "]"}]], "Input",ExpressionUUID->"439c2112-0389-4e9d-b734-a8bc0556ab07"]
},
FrontEndVersion->"15.0 for Mac OS X ARM (64-bit) (May 19, 2026)",
StyleDefinitions->"Default.nb",
ExpressionUUID->"ac6713f0-73fd-4ded-802a-451360157039"
]
