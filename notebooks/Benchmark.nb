Notebook[{
Cell["EllipticIntegrals Performance Benchmarks", "Title",ExpressionUUID->"36a6316f-ba68-4c47-b313-46debe955975"],

Cell["\<\
This notebook benchmarks the performance of the Rust-bound paclet functions \
against Wolfram Language's built-in elliptic integrals. \
\>", "Text",ExpressionUUID->"69fb9d94-ef1a-471a-8647-ba93b26f1b6f"],

Cell["Loading the Paclet", "Section",ExpressionUUID->"7cea6fa7-8c73-4961-8112-45531e96abe6"],

Cell[TextData[{
 "Ensure the paclet is loaded with the ",
 Cell[BoxData[Cell["ei`",
   Background->None,ExpressionUUID->"adf5431d-3001-4f58-b9d4-e26b6cd8e1a9"]], 
  "InlineCode",ExpressionUUID->"ddd0c90f-7531-4571-83b3-f44e1edad2f2"],
 " alias context: "
}], "CodeText",ExpressionUUID->"0c3f51a0-4b63-41b0-87d5-2482f4644588"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Load", " ", "local", " ", "paclet"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"DirectoryName", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Needs", "[", 
    RowBox[{"\"\<ArnoudBuzing`EllipticIntegrals`\>\"", "->", "\"\<ei`\>\""}], 
    "]"}]}]}]], "Input",ExpressionUUID->"6a8a0edf-615a-4ceb-834b-\
b7aa2bb071ed"],

Cell["Generating Benchmark Datasets", "Section",ExpressionUUID->"998ac81e-ebf2-4a0a-ac4c-945ef4ed0f1f"],

Cell["\<\
We generate large lists of random, unique real numbers to evaluate our \
functions over: \
\>", "CodeText",ExpressionUUID->"beb20ad7-8cd8-4ef0-9d4a-0eb7a9d9fa7f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nPoints", "=", "100000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Legendre", " ", "parameter", " ", "domains", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "<", " ", "1"}], ",", " ", 
      RowBox[{"n", " ", "<", " ", "1"}]}], ")"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataLegendre1D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "2.0"}], ",", "0.99"}], "}"}], ",", "nPoints"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dataLegendre2D", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2.0"}], ",", "0.99"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"nPoints", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Carlson", " ", "parameter", " ", "domains", " ", 
    RowBox[{"(", 
     RowBox[{"variables", " ", ">", " ", "0"}], ")"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataCarlson3D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.01", ",", "10.0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"nPoints", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataCarlson4D", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0.01", ",", "10.0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"nPoints", ",", "4"}], "}"}]}], "]"}]}], ";"}]}], "Input",Expres\
sionUUID->"fb29552f-fab0-4397-a268-aca431666ce3"],

Cell["Benchmarking Function", "Section",ExpressionUUID->"26ad4366-1f3f-462a-8823-24c880b9fa7b"],

Cell["\<\
We define a helper function to measure absolute timing for both Rust and \
built-in WL: \
\>", "CodeText",ExpressionUUID->"a89bf72d-004d-4b63-92a5-54e59f2f8479"],

Cell[BoxData[
 RowBox[{
  RowBox[{"runBenchmark", "[", 
   RowBox[{"name_String", ",", "fRust_", ",", "fWL_", ",", "data_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", "  ", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"tRust", ",", "tWL", ",", "ratio"}], "}"}], ",", 
    "\[IndentingNewLine]", "  ", 
    RowBox[{"(*", " ", 
     RowBox[{"Warm", " ", "up"}], " ", "*)"}], "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{
        RowBox[{"fRust", " ", "@@", " ", 
         RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
        "    ", 
        RowBox[{"fWL", " ", "@@", " ", 
         RowBox[{"First", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
       "    ", ",", "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"fRust", "[", 
         RowBox[{"First", "[", "data", "]"}], "]"}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"fWL", "[", 
         RowBox[{"First", "[", "data", "]"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "  ", "]"}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"tRust", "=", 
      RowBox[{"First", "[", 
       RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", "    ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
           "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fRust", " ", "@@", " ", "item"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fRust", "[", "item", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "    ", "]"}], ";"}], "\[IndentingNewLine]", 
        "  ", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"tWL", "=", 
      RowBox[{"First", "[", 
       RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", "    ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "data", "]"}], ",", "\[IndentingNewLine]", 
           "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fWL", " ", "@@", " ", "item"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"fWL", "[", "item", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"item", ",", "data"}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "    ", "]"}], ";"}], "\[IndentingNewLine]", 
        "  ", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "  ", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"<|", "\[IndentingNewLine]", "    ", 
      RowBox[{
       RowBox[{"\"\<Function\>\"", "->", "name"}], ",", "\[IndentingNewLine]",
        "    ", 
       RowBox[{"\"\<Rust Time (s)\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{"tRust", ",", "0.0001"}], "]"}]}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"\"\<WL Time (s)\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{"tWL", ",", "0.0001"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{"\"\<Speedup\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"tWL", "/", "tRust"}], ",", "0.1"}], "]"}]}]}], 
      "\[IndentingNewLine]", "  ", "|>"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",ExpressionUUID->"09c5d789-d396-4983-8f33-13d339648e65"],

Cell["Running the Benchmarks", "Section",ExpressionUUID->"97cc8b73-4df8-4a11-9704-f30cd4a1e2d7"],

Cell["Execute the speed comparisons: ", "CodeText",ExpressionUUID->"56a02302-6a52-45e9-90cf-180a0e9ea212"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{"{", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<EllipticK\>\"", ",", "ei`EllipticK", ",", "EllipticK", ",",
        "dataLegendre1D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<EllipticE\>\"", ",", "ei`EllipticE", ",", "EllipticE", ",",
        "dataLegendre1D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<EllipticPi\>\"", ",", "ei`EllipticPi", ",", "EllipticPi", ",",
        "dataLegendre2D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<EllipticD\>\"", ",", "ei`EllipticD", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"EllipticK", "[", "#", "]"}], "-", 
           RowBox[{"EllipticE", "[", "#", "]"}]}], ")"}], "/", "#"}], " ", 
        "&"}], ",", "dataLegendre1D"}], "]"}], ",", "\[IndentingNewLine]", 
     "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<CarlsonRF\>\"", ",", "ei`CarlsonRF", ",", "CarlsonRF", ",",
        "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<CarlsonRG\>\"", ",", "ei`CarlsonRG", ",", "CarlsonRG", ",",
        "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<CarlsonRD\>\"", ",", "ei`CarlsonRD", ",", "CarlsonRD", ",",
        "dataCarlson3D"}], "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"runBenchmark", "[", 
      RowBox[{"\"\<CarlsonRJ\>\"", ",", "ei`CarlsonRJ", ",", "CarlsonRJ", ",",
        "dataCarlson4D"}], "]"}]}], "\[IndentingNewLine]", "}"}]}], 
  ";"}]], "Input",ExpressionUUID->"91c5a246-f0ab-49db-ba88-3029e60f94f4"],

Cell["Displaying Results", "Section",ExpressionUUID->"a1a68a62-f863-46bd-a351-2838572d3c9b"],

Cell["Display the timing metrics as a dataset: ", "CodeText",ExpressionUUID->"4a4cc16a-03a7-4383-89df-ee7476ec6450"],

Cell[BoxData[
 RowBox[{"Dataset", "[", "results", "]"}]], "Input",ExpressionUUID->"0e421a6a-882e-4ee7-a889-f757edac0c1b"]
},
FrontEndVersion->"15.0 for Mac OS X ARM (64-bit) (May 19, 2026)",
