Cell[CellGroupData[{

Cell["Legendre Complete Elliptic Integrals", "Section",ExpressionUUID->"60398cf2-7850-4a1c-97f8-c68e6fce9ed0"],

Cell[TextData[{
 "The complete elliptic integrals are defined in terms of the parameter ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> "m", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "70caef29-ad08-44a8-b0b7-281968809356"],
 ". "
}], "Text",ExpressionUUID->"df09e999-646e-4398-866e-281746f3c058"],

Cell[CellGroupData[{

Cell[TextData[{
 "Complete Elliptic Integral of the First Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["K", "TI"], "(", 
         StyleBox["m", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "K(m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "33acc853-b9ac-4e0d-a0d9-138c46590804"]
}], "Subsection",ExpressionUUID->"e2aa5cf2-ccec-4b71-851b-23f5a79a1054"],

Cell["Evaluate $K(0.5)$ using the Rust binding: ", "CodeText",ExpressionUUID->"1cdbc98c-cbbf-4d8a-9016-eea156d1b12d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rEllipticK", "[", "0.5", "]"}]], "Input",
 CellLabel->"In[46]:=",ExpressionUUID->"d97b17ab-d521-45f9-842e-4cd784a48b37"],

Cell[BoxData["1.854074677301372`"], "Output",
 CellChangeTimes->{3.991823018407312*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"60e01219-8708-4f96-b0ce-9c6632649e93"]
}, Open  ]],

Cell[TextData[{
 "Compare with the built-in ",
 Cell[BoxData[
  TemplateBox[{
   "EllipticK", "paclet:ref/EllipticK", 
    "https://reference.wolfram.com/language/ref/EllipticK.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
