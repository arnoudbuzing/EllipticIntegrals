Cell["Bulirsch Elliptic Integrals", "Section",ExpressionUUID->"4866de68-ac9e-4d80-afa4-7ca633b3bbc1"],

Cell["\<\
Bulirsch integrals provide high-speed, general representations of complete \
and incomplete elliptic integrals. \
\>", "Text",ExpressionUUID->"ac3f24b8-7187-4470-8beb-a38857c0fc61"],

Cell[TextData[{
 "Complete Integral ",
 Cell[BoxData[Cell["Cel",
   Background->None,ExpressionUUID->"d43a66bf-c9f6-429c-aea2-11f8bb5deed1"]], 
  "InlineCode",ExpressionUUID->"f688323c-ba2a-43ab-9e73-2a2c9d2f0db6"]
}], "Subsection",ExpressionUUID->"68e45798-7645-486e-b061-ba09c6326b8e"],

Cell[TextData[{
 "Calculate Bulirsch's general complete elliptic integral ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cel", "(", 
         RowBox[{
           SubscriptBox[
            StyleBox["k", "TI"], 
            StyleBox["c", "TI"]], ",", 
           StyleBox["p", "TI"], ",", 
           StyleBox["a", "TI"], ",", 
           StyleBox["b", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\text{cel}(k_c, p, a, b)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6641d034-c2f4-4792-8c62-7fe85934510e"],
 ": "
}], "CodeText",ExpressionUUID->"fcf08c07-79e3-4d99-a102-a3e4bcc03b68"],

Cell[BoxData[
 RowBox[{"ei`Cel", "[", 
  RowBox[{"0.5", ",", "0.2", ",", "1.0", ",", "2.0"}], "]"}]], "Input",Express\
ionUUID->"a1a95b0b-228e-4876-ac67-86b5b0c69c8e"],

Cell[TextData[{
 "Incomplete Integral ",
 Cell[BoxData[Cell["El1",
   Background->None,ExpressionUUID->"91baf8d7-ecc7-4313-8e7a-3b69acadecc3"]], 
  "InlineCode",ExpressionUUID->"f6f4525a-a2b1-475f-a0bb-b8f52277a4cf"]
}], "Subsection",ExpressionUUID->"47c4a64c-d71c-48be-a2e7-ebb6a68d90e3"],

Cell[TextData[{
 "Evaluate Bulirsch's general incomplete elliptic integral of the first kind ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"el1", "(", 
         RowBox[{
           StyleBox["x", "TI"], ",", 
           SubscriptBox[
            StyleBox["k", "TI"], 
            StyleBox["c", "TI"]]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\text{el1}(x, k_c)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5bfd5a28-7702-4078-aacf-a78442fc066f"],
 ": "
}], "CodeText",ExpressionUUID->"82b6a740-12ff-48fb-aec5-db03edcbc881"],

Cell[BoxData[
 RowBox[{"ei`El1", "[", 
  RowBox[{"1.0", ",", "0.5"}], "]"}]], "Input",ExpressionUUID->"d2dc7406-f40d-\
42e8-aad2-d628978d06a9"],

