     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "c85d7cc4-0505-43ec-b814-86557a6f9b00"],
 " (",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["n", "TI"], ",", "\[Phi]", ",", 
         StyleBox["m", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n, \\phi, m", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e28723ae-9a03-4900-a704-151270321645"],
 "): "
}], "CodeText",ExpressionUUID->"a728ecd7-baf8-47cc-a3aa-94ad13a3e3b6"],

Cell[BoxData[
 RowBox[{"rEllipticPi", "[", 
  RowBox[{"0.2", ",", "1.0", ",", "0.5"}], "]"}]], "Input",ExpressionUUID->\
"a975e598-c3bc-4920-882f-ff4009d6005c"],

