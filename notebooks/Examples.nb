Cell[CellGroupData[{

Cell["Bulirsch Elliptic Integrals", "Section",ExpressionUUID->"31234c3c-22e1-42d7-b772-b95c380bed35"],

Cell["\<\
Bulirsch integrals provide high-speed, general representations of complete \
and incomplete elliptic integrals. \
\>", "Text",ExpressionUUID->"b1fc5da4-124a-45c5-abc6-ca75b74bf228"],

Cell[CellGroupData[{

Cell[TextData[{
 "Complete Integral ",
 Cell[BoxData[Cell["rCel",
   Background->None,ExpressionUUID->"7581af0c-ff56-4a9e-8b1d-de9b497e1c5b"]], 
  "InlineCode",ExpressionUUID->"118e2a58-bbb9-40d2-9e23-3854ccf49ee2"]
}], "Subsection",ExpressionUUID->"3095f8ea-4090-42ed-abc0-d408f1ec3680"],

Cell[TextData[{
 "Calculate Bulirsch's general complete elliptic integral ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"cel", "(", 
         RowBox[{
           SubscriptBox[
            StyleBox["k", "TI"], 
            StyleBox["c", "TI"]], ",", 
           StyleBox["p", "TI"], ",", 
           StyleBox["a", "TI"], ",", 
           StyleBox["b", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\text{cel}(k_c, p, a, b)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6a04e715-ddb0-4f93-8331-64ceca6ec544"],
 ": "
}], "CodeText",ExpressionUUID->"234cd893-dd7c-4f43-90f6-43e6ade13dd7"],

Cell[BoxData[
 RowBox[{"rCel", "[", 
  RowBox[{"0.5", ",", "0.2", ",", "1.0", ",", "2.0"}], "]"}]], "Input",Express\
ionUUID->"d8913c2b-3113-4a0b-844a-b422112b01f3"]
}, Open  ]],

