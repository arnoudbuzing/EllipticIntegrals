Cell[CellGroupData[{

Cell["Loading the Paclet", "Section",ExpressionUUID->"d2f36914-ccc4-4443-a2c0-f11f412fa209"],

Cell[TextData[{
 "Because the paclet functions match the built-in Wolfram Language function \
names (to avoid symbol shadowing conflicts), we load the package using an ",
 StyleBox["alias context",
  FontWeight->Bold],
 " ",
 Cell[BoxData[Cell["ei`",
   Background->None,ExpressionUUID->"90d5009d-7d59-4239-afe7-a28c921d2bb3"]], 
  "InlineCode",ExpressionUUID->"fec80213-6f9e-4ff0-9e30-d3655c19c4b6"],
