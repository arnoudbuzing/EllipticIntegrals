Cell["EllipticIntegrals Paclet Examples", "Title",ExpressionUUID->"68d0f0b6-14ea-4e6e-b757-bfa904c3085d"],

Cell[TextData[{
 "This notebook demonstrates how to load and use the ",
 Cell[BoxData[Cell["ArnoudBuzing/EllipticIntegrals",
   Background->None,ExpressionUUID->"5799d984-99df-4516-b07b-18ba79a87747"]], 
  "InlineCode",ExpressionUUID->"75914f37-e86a-4bca-85df-6a0be361b07e"],
 " paclet. "
}], "Text",ExpressionUUID->"eecc9747-7963-4d01-8d17-e697088f2849"],

Cell["Loading the Paclet", "Section",ExpressionUUID->"d2f36914-ccc4-4443-a2c0-f11f412fa209"],

Cell[TextData[{
 "Because the paclet functions match the built-in Wolfram Language function \
names (to avoid symbol shadowing conflicts), we load the package using an ",
 StyleBox["alias context",
  FontWeight->Bold],
 " ",
 Cell[BoxData[Cell["ei`",
   Background->None,ExpressionUUID->"90d5009d-7d59-4239-afe7-a28c921d2bb3"]], 
  "InlineCode",ExpressionUUID->"fec80213-6f9e-4ff0-9e30-d3655c19c4b6"],
 ": "
}], "CodeText",ExpressionUUID->"9d6e51d3-60e6-470e-891b-6269f422dc3e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Load", " ", "local", " ", "paclet", " ", "with", " ", "alias"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"DirectoryName", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Needs", "[", 
    RowBox[{"\"\<ArnoudBuzing`EllipticIntegrals`\>\"", "->", "\"\<ei`\>\""}], 
    "]"}]}]}]], "Input",ExpressionUUID->"43cb3822-4d95-4ba9-8fe2-\
995f3c8a22b5"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     TemplateBox[{0},
      "Spacer1"]},
    {
