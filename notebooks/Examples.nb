Cell[TextData[{
 "Incomplete Elliptic Integral of the Second Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["E", "TI"], "(", 
         RowBox[{"\[Phi]", ",", 
           StyleBox["m", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "E(\\phi, m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "58f938a8-b491-4a03-b013-a46ded343e1e"]
}], "Subsection",ExpressionUUID->"04e8c19f-c5e3-4d1c-aa74-4d741f0bd874"],

Cell["Evaluate $E(1.0, 0.5)$: ", "CodeText",ExpressionUUID->"1ff1ec82-a323-48c8-857e-f59f8f08887f"],

Cell[BoxData[
 RowBox[{"rEllipticE", "[", 
  RowBox[{"1.0", ",", "0.5"}], "]"}]], "Input",ExpressionUUID->"0e7b3bca-a94e-\
4d7f-bd33-a69f08018a99"],

Cell[TextData[{
 "Incomplete Elliptic Integral of the Third Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalPi]", "(", 
         RowBox[{
           StyleBox["n", "TI"], ";", "\[Phi]", ",", 
           StyleBox["m", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Pi(n; \\phi, m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9c1b2832-aa2f-4964-b10e-e503c5d5780d"]
}], "Subsection",ExpressionUUID->"370e0902-bd89-45d7-bf03-906bb7cbd65c"],

Cell[TextData[{
 "Note that the argument order is consistent with the built-in ",
 Cell[BoxData[
  TemplateBox[{
   "EllipticPi", "paclet:ref/EllipticPi", 
    "https://reference.wolfram.com/language/ref/EllipticPi.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
