      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "d4e22b8e-89ff-4dbe-8683-90a1209f1370"],
 ": "
}], "CodeText",ExpressionUUID->"f3b9841c-6ff2-4807-98db-17f8828f4a17"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"rEllipticK", "[", "0.5", "]"}], "-", 
  RowBox[{"EllipticK", "[", "0.5", "]"}]}]], "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"8229d350-c625-48b8-9ca9-4273e8c57aa6"],

