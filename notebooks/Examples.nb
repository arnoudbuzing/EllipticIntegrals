Cell[BoxData[
 RowBox[{"ei`EllipticE", "[", 
  RowBox[{"1.0", ",", "0.5"}], "]"}]], "Input",ExpressionUUID->"87dd9aa9-dcd6-\
40d4-9f62-96385de16723"],

Cell[TextData[{
 "Incomplete Elliptic Integral of the Third Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalPi]", "(", 
         RowBox[{
           StyleBox["n", "TI"], ";", "\[Phi]", ",", 
           StyleBox["m", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\Pi(n; \\phi, m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "76a5becc-0197-4e88-a9de-16d571654d0d"]
}], "Subsection",ExpressionUUID->"154bad37-57fd-4edc-862c-5723e1b68b62"],

