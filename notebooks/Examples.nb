 ShowStringCharacters->False,
 Background->None,ExpressionUUID->"1783eba0-6fae-40b5-a0a6-a30e2f256cc3"],

Cell["Legendre Complete Elliptic Integrals", "Section",ExpressionUUID->"edb3c1a6-7e77-4eea-9225-379fce75e679"],

Cell[TextData[{
 "The complete elliptic integrals are defined in terms of the parameter ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> "m", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9fee810-ca15-4252-863d-26db220015bd"],
 ". "
}], "Text",ExpressionUUID->"d6711029-e5ed-476b-83c3-af598d897aeb"],

Cell[TextData[{
 "Complete Elliptic Integral of the First Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["K", "TI"], "(", 
         StyleBox["m", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "K(m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "664a067f-270f-4f6d-8843-b5096b7234e4"]
}], "Subsection",ExpressionUUID->"d754c686-7c58-4a5e-8f25-8a0e950e9010"],

