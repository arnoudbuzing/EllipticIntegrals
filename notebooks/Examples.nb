Cell["EllipticIntegrals Paclet Examples", "Title",ExpressionUUID->"ffa1ea89-2123-4a65-9701-a499869cee9d"],

Cell[TextData[{
 "This notebook demonstrates how to load and use the ",
 Cell[BoxData[Cell["ArnoudBuzing/EllipticIntegrals",
   Background->None,ExpressionUUID->"32ce6c1e-4c1d-4ea8-9124-ed47440ac2ee"]], 
  "InlineCode",ExpressionUUID->"1b34389e-796b-4efb-9f48-d0959e1ec55c"],
 " paclet. "
}], "Text",ExpressionUUID->"696aa3b2-7970-4921-8161-1ab3cf361a01"],

Cell["Loading the Paclet", "Section",ExpressionUUID->"941bdcbe-0681-4540-88ea-e95c5aaad4c5"],

Cell["\<\
First, ensure the paclet is loaded in your Wolfram Language session. We load \
it using the directory path: \
\>", "CodeText",ExpressionUUID->"f1118012-e0bd-45da-9b93-78fec0b0ca31"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Load", " ", "local", " ", "paclet"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletDirectoryLoad", "[", 
     RowBox[{"DirectoryName", "[", 
      RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Needs", "[", "\"\<ArnoudBuzing`EllipticIntegrals`\>\"", 
    "]"}]}]}]], "Input",ExpressionUUID->"1b54d8a7-b26a-4f9f-8f8f-\
6a4f4e19a209"],

