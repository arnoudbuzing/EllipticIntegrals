"c635585e-946f-4964-81f4-4fb0952cc40e"],

Cell[TextData[{
 "Complete Elliptic Integral of the Second Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
