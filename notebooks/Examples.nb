Cell["Legendre Incomplete Elliptic Integrals", "Section",ExpressionUUID->"d1dc53c0-2b00-4c1c-93d3-5ae5564db28e"],

Cell[TextData[{
 "Incomplete Elliptic Integral of the Second Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["E", "TI"], "(", 
         RowBox[{"\[Phi]", ",", 
           StyleBox["m", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "E(\\phi, m)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0c111131-1937-4a15-bef8-fdae48a52e76"]
}], "Subsection",ExpressionUUID->"0dc66a4d-de7b-4e8a-9df4-34de4c0fd0b2"],

