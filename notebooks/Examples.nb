"8229d350-c625-48b8-9ca9-4273e8c57aa6"],

Cell[TextData[{
 "Complete Elliptic Integral of the Second Kind: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["E", "TI"], "(", 
