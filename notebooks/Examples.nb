Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Load", " ", "local", " ", "paclet", " ", "with", " ", "alias"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"PacletDirectoryLoad", "[", 
    RowBox[{"DirectoryName", "[", 
     RowBox[{"NotebookDirectory", "[", "]"}], "]"}], "]"}], ";"}]}]], "Input",\

 CellChangeTimes->{3.991824690849595*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"43cb3822-4d95-4ba9-8fe2-995f3c8a22b5"],

