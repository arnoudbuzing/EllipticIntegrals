}], "Subsection",ExpressionUUID->"7b580c18-9564-4e29-8d35-2bd2d58f4ace"],

Cell["Evaluate $E(0.5)$: ", "CodeText",ExpressionUUID->"51df9b93-ed85-4ab1-a7f4-21cc0868dd9f"],

Cell[BoxData[
 RowBox[{"rEllipticE", "[", "0.5", "]"}]], "Input",ExpressionUUID->"dd5ad505-9524-4a2b-a93f-647ac81a4c09"],

